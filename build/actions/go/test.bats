    [[ "$output" == *"GONOSUMDB"* ]]
}

@test "go.checks (L4): install_govulncheck refuses to run with GOINSECURE set (regression: bypass-var detection)" {
    need_go
    local shim_info shim_dir
    shim_info="$(_setup_go_shim)"
