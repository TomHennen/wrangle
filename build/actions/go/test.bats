    [[ "$status" -eq 0 ]]
}

@test "tools/syft/generate_sbom.sh uses set -f" {
    run grep '^set -f' "$REPO_ROOT/tools/syft/generate_sbom.sh"
    [[ "$status" -eq 0 ]]
}

@test "go: compute_metadata.sh uses set -f" {
    run grep '^set -f' "$GO_ACTION_DIR/compute_metadata.sh"
    [[ "$status" -eq 0 ]]
