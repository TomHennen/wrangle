{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "test-tool",
          "version": "1.0.0",
          "rules": [
            {
              "id": "TEST-001",
              "shortDescription": {
                "text": "Test finding"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "TEST-001",
          "level": "error",
          "message": {
            "text": "A test vulnerability was found"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/main.c"
                },
                "region": {
                  "startLine": 10
                }
              }
            }
          ]
        },
        {
          "ruleId": "TEST-001",
          "level": "warning",
          "message": {
            "text": "Another test finding"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/utils.c"
                },
                "region": {
                  "startLine": 42
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
