
        {
            // 8. OpenSSF Scorecard aggregate score is at least 7.0. No upstream
            //    policy computes the aggregate, so it is authored inline; -1.0
            //    forces FAIL when the score is absent (fail-closed).
            id: "wrangle-scorecard-min-score"
            meta: { description: "OpenSSF Scorecard aggregate score is at least 7.0" }
            identities: [ { ref: { id: "wrangle-builder" } } ]
            tenets: [
                {
                    predicates: { types: ["https://scorecard.dev/result/v0.1"] }
                    outputs: {
                        score: { code: "has(predicates[0].data.score) ? double(predicates[0].data.score) : -1.0" }
                    }
                    code: "outputs.score >= 7.0"
                    assessment: { message: "Scorecard aggregate score meets the >= 7.0 bar" }
                    error: {
                        message: "Scorecard aggregate score below 7.0 or no Scorecard attestation was found"
                        guidance: "Raise the OpenSSF Scorecard score to at least 7.0 before release"
                    }
                }
            ]
        }
